	)
	(text "Battery charging and USB power stage. Output 3.3V.\nILIM controls input current limit calculated by 1550/R = limit.\n3k = 500mA | 1k8 = 860mA\nISET controls battery current charge limit calculated by 890/R = limit.\n1.8k = 500mA | 1k = 890mA\n\nWhite LED for charging status with CHG. TPS2291 load switch for better\nstability when turning on/off. White LED for USB Power connection\n\nOptional film NTC thermistor for battery."
		(exclude_from_sim no)
		(at 244.094 127.254 0)
		(effects
			(font
				(size 1 1)
				(thickness 0.125)
			)
		)
		(uuid "7461a461-fe97-49ce-ad9c-d48c199c0dee")
	)
